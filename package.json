{
  "name": "charmssandalias",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev": "concurrently -n worker,web -c cyan,green \"npm run dev:worker\" \"npm run dev:web\"",
    "dev:web": "npm --workspace @charms/web run dev",
    "dev:worker": "npm --workspace @charms/worker run dev",
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "seed": "ts-node -P scripts/tsconfig.json -r tsconfig-paths/register scripts/seed-demo.ts",
    "seed:clean": "ts-node -P scripts/tsconfig.json -r tsconfig-paths/register scripts/seed-demo.ts --clean",
    "migrate:kommo": "ts-node -P scripts/tsconfig.json -r tsconfig-paths/register scripts/migrate-kommo.ts"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "zod": "^3.23.2"
  },
  "engines": {
    "node": ">=20"
  }
}
